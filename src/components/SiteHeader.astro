---
const base = import.meta.env.BASE_URL;

// Added trailing slashes to hrefs for better compatibility with GitHub Pages
const nav = [
  { label: "About", href: `${base}about/` },
  { label: "Programs", href: `${base}programs/` },
  { label: "Impact", href: `${base}impact/` },
  { label: "Get Involved", href: `${base}get-involved/` },
  { label: "Donate", href: `${base}donate/` },
  { label: "Events", href: `${base}events/` },
  { label: "Stories", href: `${base}stories/` },
  { label: "Resources", href: `${base}resources/` },
  { label: "News", href: `${base}news/` },
  { label: "Contact", href: `${base}contact/` },
];
---
<a class="skip-link" href="#main">Skip to content</a>

<header class="header">
  <div class="container header-inner">
    <a class="brand" href={base}>
      <img src={`${base}images/bfn-logo.png`} alt="Bright Futures Network logo" />
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((i) => <a href={i.href}>{i.label}</a>)}
      <a class="cta" href={`${base}donate/`}>Donate</a>
    </nav>

    <button class="mobile-toggle" type="button" aria-expanded="false" aria-controls="mobile-drawer">
      Menu
    </button>
  </div>

  <div class="container mobile-drawer" id="mobile-drawer">
    {nav.map((i) => <a href={i.href}>{i.label}</a>)}
    <a class="cta" href={`${base}donate/`}>Donate</a>
  </div>
</header>

<script>
  const btn = document.querySelector(".mobile-toggle");
  const drawer = document.querySelector("#mobile-drawer") as HTMLElement;
  if (btn && drawer) {
    btn.addEventListener("click", () => {
      // Check for both empty string and 'none' to ensure the toggle works on first click
      const isHidden = !drawer.style.display || drawer.style.display === "none";
      drawer.style.display = isHidden ? "block" : "none";
      btn.setAttribute("aria-expanded", String(isHidden));
    });
  }
</script>