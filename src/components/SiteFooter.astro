        <a
          class="whatsapp-inline"
          href={`https://wa.me/${whatsappNumber}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          Message on WhatsApp
        </a>
      </div>
      <div><strong>Location:</strong> Texas</div>
    </div>

    <p class="small" style="margin-top:12px;">
      © {year} Bright Futures Network. Built by Vibes Digital Media.
      <span class="ai-credit">AI chat & experience by VDM</span>
    </p>
  </div>
</footer>

<a
  href={`https://wa.me/${whatsappNumber}`}
  class="whatsapp-fab"
  target="_blank"
  rel="noopener noreferrer"
